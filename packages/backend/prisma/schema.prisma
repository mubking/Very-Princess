// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id
  name      String
  admin     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model Transaction {
  id            String   @id @default(cuid())
  txHash        String   // Blockchain transaction hash
  eventIndex    Int      // Index of the event within the transaction
  walletAddress String
  volumeUSD     Decimal
  createdAt     DateTime @default(now())
  type          String   // e.g., "PAYOUT_ALLOCATED", "ORG_FUNDED", "PAYOUT_CLAIMED"
  ledger        Int      // Ledger sequence number
  rawData       String?  // JSON-encoded raw event data for debugging

  @@unique([txHash, eventIndex]) // Prevents duplicate processing
  @@index([createdAt])
  @@index([walletAddress])
  @@index([txHash])
  @@index([ledger])
}

model IndexerState {
  id                  String   @id @default("default")
  lastProcessedLedger Int
  updatedAt           DateTime @updatedAt
}

model VerifiedContract {
  address    String   @id
  isVerified Boolean  @default(true)
  riskLevel  String   @default("LOW") // LOW, MEDIUM, HIGH
  createdAt  DateTime @default(now())

  @@index([address])
}

enum InvoiceStatus {
  ACTIVE      // Minted and currently active
  REPAID      // Fully repaid/settled
  CANCELLED   // Cancelled before repayment
  OVERDUE     // Past due date but not repaid
}

model Invoice {
  id           String        @id @default(cuid())
  invoiceId    String        @unique // On-chain invoice identifier
  faceValue    Decimal       // Value in stroops (smallest unit)
  faceValueUSD Decimal       // Value in USD (for stablecoin/oracle integration)
  status       InvoiceStatus @default(ACTIVE)
  issuer       String        // Wallet address of issuer
  holder       String?       // Current holder address (if transferred)
  dueDate      DateTime?     // Optional due date
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  repaidAt     DateTime?     // When the invoice was repaid

  @@index([status])
  @@index([issuer])
  @@index([createdAt])
}
