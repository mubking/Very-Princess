# ─────────────────────────────────────────────────────────────────────────────
# very-princess — Environment Configuration
# Copy this file to `.env` and fill in your own values.
# NEVER commit `.env` to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Stellar Network ─────────────────────────────────────────────────────────

# Horizon REST API endpoint (defaults to Stellar Testnet)
HORIZON_URL=https://horizon-testnet.stellar.org

# Soroban RPC endpoint (defaults to Stellar Testnet)
RPC_URL=https://soroban-testnet.stellar.org

# Network passphrase — used for transaction signing
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# ─── Contract ────────────────────────────────────────────────────────────────

# The deployed PayoutRegistry contract ID on Testnet.
# This is written automatically by scripts/deploy.sh after deployment.
CONTRACT_ID=

# ─── Backend Server ──────────────────────────────────────────────────────────

PORT=3001
HOST=0.0.0.0

# ─── Deployer Keypair (contracts/scripts/deploy.sh only) ─────────────────────
# The SECRET key of a funded Testnet Stellar account.
# Get a funded Testnet account at: https://developers.stellar.org/network/testnet/get-started
# WARNING: Never use a Mainnet keypair here.
DEPLOYER_SECRET=
